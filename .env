# Application
NODE_ENV=development
PORT=3006
RUNTIME=bun
ELYSIA_VERSION=1.0.0

# Database Configuration (used by env.ts to build DATABASE_URL)
PGHOST=localhost
PGPORT=5434
PGDATABASE=catalog_db
PGUSER=postgres
PGPASSWORD=postgres
PGIDLE_TIMEOUT=0
PGCONNECT_TIMEOUT=30

# Docker Compose variables
POSTGRES_DB=catalogdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_DB=catalog_db

# Database URL (constructed from above variables: postgres://PGUSER:PGPASSWORD@PGHOST:PGPORT/PGDATABASE)
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/catalog_db"