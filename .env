# Application
NODE_ENV=development
PORT=8080
RUNTIME=bun
ELYSIA_VERSION=1.0.0

# Database Configuration (used by env.ts to build DATABASE_URL)
PGHOST=catalog-postgres
PGPORT=5432
PGDATABASE=catalogdb
PGUSER=admin
PGPASSWORD=admin
PGIDLE_TIMEOUT=0
PGCONNECT_TIMEOUT=30

# Docker Compose variables
POSTGRES_DB=catalogdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
DATABASE_USER=admin
DATABASE_PASSWORD=admin
DATABASE_DB=catalogdb

# Database URL (constructed from above variables: postgres://PGUSER:PGPASSWORD@PGHOST:PGPORT/PGDATABASE)
DATABASE_URL="postgresql://admin:admin@localhost:5432/catalogdb"

JWT_PUBLIC_KEY_BASE64=""
