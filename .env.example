# Application
NODE_ENV=development
PORT=3006
RUNTIME=bun

# Database Configuration
PGHOST=localhost
PGPORT=5434
PGDATABASE=catalog_db
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGCONNECT_TIMEOUT=30
PGIDLE_TIMEOUT=0

# Docker Compose variables
POSTGRES_DB=catalog_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME
DATABASE_DB=catalog_db

# Database URL
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5434/catalog_db"

# JWT (get the public key from the auth-service team)
JWT_PUBLIC_KEY_BASE64="REPLACE_WITH_JWT_PUBLIC_KEY_BASE64"
